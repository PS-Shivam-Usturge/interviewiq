# Copy this to .env and fill in your keys

# ── Claude Agent SDK (ALL LLM calls — orchestration + sub-agents) ─────────────
# Run `claude setup-token` in your terminal to generate this token.
# Authenticates via your Claude Pro subscription — no separate API billing.
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-your-token-here

# ── Groq (Whisper STT only — Claude has no audio model) ──────────────────────
# Get a free key at: https://console.groq.com
# Only used for POST /api/transcribe — not for any LLM text calls.
GROQ_API_KEY=your_groq_api_key_here

# Which provider to use for text LLM calls (parseAgent, questionAgent, etc.)
#   claude-sdk  = Claude Agent SDK with CLAUDE_CODE_OAUTH_TOKEN (default, recommended)
#   groq        = Llama 3.3 70B via Groq free tier
#   gemini      = Gemini 2.5 Flash Lite via Google AI Studio free tier
LLM_PROVIDER=claude-sdk

PORT=3001